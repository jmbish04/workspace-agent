{
  "name": "workspace-agent",
  "version": "1.0.0",
  "description": "Edge-native AI assistant for Google Workspace orchestration on Cloudflare Workers",
  "license": "MIT",
  "author": {
    "name": "jmbish04",
    "url": "https://github.com/jmbish04"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jmbish04/workspace-agent"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "start": "astro dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate",
    "migrate:local": "pnpm run db:generate && npx wrangler d1 migrations apply DB --local",
    "migrate:remote": "pnpm run db:generate && npx wrangler d1 migrations apply DB --remote",
    "deploy": "pnpm run build && pnpm run migrate:remote && npx wrangler deploy",
    "types": "wrangler types"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.12.17",
    "@assistant-ui/react-markdown": "latest",
    "@astrojs/cloudflare": "^12.1.0",
    "@astrojs/react": "^4.4.2",
    "@base-ui/react": "^1.2.0",
    "@cloudflare/ai-chat": "latest",
    "@cloudflare/workers-types": "^4.20250224.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "latest",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "agents": "latest",
    "ai": "^6.0.116",
    "astro": "^5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.33.0",
    "googleapis": "^144.0.0",
    "hono": "^4.12.7",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-resizable-panels": "^4.7.2",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.24.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
}
