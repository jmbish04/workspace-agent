{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "types": [
      "@cloudflare/workers-types"
    ],
    "paths": {
      "@/*": ["src/*"],
      "@frontend/*": ["src/frontend/*"],
      "@backend/*": ["src/backend/*"],
      "@components/*": ["src/components/*"],
      "@lib/*": ["src/lib/*"]
    }
  },
  "include": [
    ".astro/types.d.ts",
    "src/**/*",
    "worker-configuration.d.ts"
  ]
}
