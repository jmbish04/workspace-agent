{
  "name": "@126colby/core-template-cfw-assets-astro-shadcn",
  "version": "26.02.24",
  "description": "The template helps you build apps with Astro, Tailwind CSS, and shadcn/ui.",
  "license": "MIT",
  "author": {
    "name": "126colby",
    "url": "https://github.com/126colby"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/126colby/core-template-cfw-assets-astro-shadcn"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "wrangler dev",
    "start": "astro dev",
    "fmt": "oxfmt",
    "lint": "oxlint",
    "check": "oxlint && oxfmt",
    "db:generate": "drizzle-kit generate",
    "migrate:local": "pnpm run db:generate && npx wrangler d1 migrations apply DB --local",
    "migrate:remote": "pnpm run db:generate && npx wrangler d1 migrations apply DB --remote",
    "deploy": "pnpm run build && pnpm run migrate:remote && npx wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250224.0",    
    "@astrojs/cloudflare": "^12.1.0",
    "@astrojs/react": "^4.4.2",
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "astro": "^5.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.33.0",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.11.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.24.0",
    "oxfmt": "^0.35.0",
    "oxlint": "^1.50.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.71.0"
  }
}
